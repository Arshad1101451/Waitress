# Tauri mobile — regenerated by `tauri android init` / `tauri ios init`,
# safe to delete and re-run; excluded so signing/build caches never bloat
# the repo (see project history: an earlier unbounded `path = "."` bundling
# bug produced 2GB+ builds, so anything regenerable stays out of git).
src-tauri/gen/
src-tauri/target/

